{
  "name": "risuai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --sourcemap",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:strict": "svelte-check --tsconfig ./tsconfig.strict.json",
    "check:strict:ratchet": "node dev/check-strict-ratchet.cjs",
    "check:prototype:classes": "node prototypes/structure-lab/moescape-concept/dev/check-template-classes.js",
    "check:prototype:design": "node prototypes/structure-lab/moescape-concept/dev/check-design-rules.js",
    "check:prototype": "node --check prototypes/structure-lab/moescape-concept/app.js && pnpm run check:prototype:classes && pnpm run check:prototype:design",
    "check:server:routes": "node server/node/check-server-routes.cjs",
    "check:server:api": "node server/node/check-api-surface.cjs",
    "check:server:deps": "node server/node/check-server-deps.cjs",
    "check:server:errors": "node server/node/check-error-handling.cjs",
    "check:server:contracts": "node server/node/check-server-contracts.cjs",
    "check:server": "pnpm run check:server:routes && pnpm run check:server:deps && pnpm run check:server:errors && pnpm run check:server:api",
    "check:settings-contract": "node dev/check-settings-contract.js",
    "check:settings-shell": "node dev/check-settings-shell.js",
    "check:chat-runtime": "pnpm exec vitest run dev/chat-runtime-smoke.test.ts",
    "check:ui-shell-contract": "node dev/check-ui-shell-contract.js",
    "check:ui-shell-runtime": "pnpm exec vitest run dev/ui-shell-runtime-smoke.test.ts",
    "check:ui-shell-smoke": "node dev/check-ui-shell-smoke.js",
    "check:settings-smoke": "node dev/check-settings-smoke.js",
    "test": "vitest run",
    "lint": "eslint src server/node dev public/sw.js",
    "tauri": "tauri",
    "buildsite": "vite build --outDir dist",
    "runserver": "node server/node/server.cjs",
    "runserver:tmp": "SERE_DATA_ROOT=/tmp/risu-smoke-data node server/node/server.cjs",
    "runserver:test": "SERE_DATA_ROOT=./.dev-test-data node server/node/server.cjs",
    "smoke:reset-test": "node -e \"require('fs').rmSync('.dev-test-data', {recursive:true,force:true}); console.log('test data cleared')\"",
    "test:server:unit": "node scripts/test-memory-unit.cjs && node scripts/test-server-http-setup-unit.cjs && pnpm exec vitest run server/node/routes/hypav3_manual_routes.test.ts",
    "smoke:server:safe": "RISU_STORAGE_TEST_ALLOW_WRITE=1 RISU_DATA_TEST_URL=http://localhost:6001 node scripts/test-server-storage.js && RISU_DATA_TEST_URL=http://localhost:6001 node scripts/test-server-llm-phaseA.js && RISU_STORAGE_TEST_ALLOW_WRITE=1 RISU_DATA_TEST_URL=http://localhost:6001 node scripts/test-server-memory.js && RISU_STORAGE_TEST_ALLOW_WRITE=1 RISU_DATA_TEST_URL=http://localhost:6001 node scripts/test-server-rag.js",
    "smoke:server:auth": "RISU_DATA_TEST_URL=http://localhost:6001 node scripts/test-server-auth.js",
    "smoke:memory:api": "RISU_STORAGE_TEST_ALLOW_WRITE=1 RISU_DATA_TEST_URL=http://localhost:6001 node scripts/test-server-memory.js",
    "smoke:rag:api": "RISU_STORAGE_TEST_ALLOW_WRITE=1 RISU_DATA_TEST_URL=http://localhost:6001 node scripts/test-server-rag.js",
    "smoke:migration:api": "RISU_STORAGE_TEST_ALLOW_WRITE=1 RISU_DATA_TEST_URL=http://localhost:6001 node dev/run-migration-smoke-pack.js",
    "smoke:app:auto": "node dev/run-full-app-smoke.js",
    "test:pdf-cleanup": "node dev/test-rag-pdf-cleanup.cjs",
    "hono:build": "vite build --sourcemap && node server/hono/src/utils/postbuild.js"
  },
  "dependencies": {
    "@adobe/css-tools": "4.4.4",
    "@aws-crypto/sha256-js": "^5.2.0",
