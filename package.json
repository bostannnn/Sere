    "svelte-check": "^4.3.5",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.0",
    "vite-plugin-wasm": "3.5.0",
    "vitest": "^4.0.16"
  },
  "pnpm": {
