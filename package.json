    "node-html-parser": "^6.1.13",
    "ollama": "^0.5.18",
    "openid-client": "^6.8.1",
    "pdfjs-dist": "^4.10.38",
    "peerjs": "^1.5.5",
    "png-chunk-text": "^1.0.0",
    "postcss-selector-parser": "^7.1.1",
    "pyodide": "^0.27.7",
    "rfdc": "^1.4.1",
    "sortablejs": "^1.15.6",
    "streamsaver": "^2.0.6",
    "sucrase": "^3.35.1",
    "sv": "^0.11.0",
    "svelte-awesome-color-picker": "^4.1.0",
    "three": "^0.154.0",
    "tippy.js": "^6.3.7",
    "uuid": "^9.0.1",
    "wasmoon": "^1.16.0",
    "wavefile": "^11.0.0",
    "web-streams-polyfill": "^3.3.3"
  },
