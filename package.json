    "@types/showdown": "^2.0.6",
    "@types/sortablejs": "^1.15.9",
    "@types/streamsaver": "^2.0.5",
    "@types/three": "^0.154.0",
    "@types/uuid": "^9.0.8",
    "@types/wicg-file-system-access": "^2020.9.8",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-plugin-svelte": "^3.15.0",
    "fast-check": "^4.5.3",
    "globals": "^17.3.0",
    "happy-dom": "^20.1.0",
    "internal-ip": "^7.0.0",
    "postcss": "^8.5.6",
    "source-map": "^0.7.6",
    "supertest": "^7.2.2",
